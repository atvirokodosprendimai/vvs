# vvs-stb environment — runs on public-facing VPS (IPTV STB device API)
# Copy to /etc/vvs/stb.env and fill in values.

STB_ADDR=:8082

# WireGuard tunnel IP of vvs-core NATS listener (must match NATS_LISTEN_ADDR in core.env)
NATS_URL=nats://10.0.0.1:4222

# Must match NATS_AUTH_TOKEN in core.env
NATS_AUTH_TOKEN=replace-with-a-strong-random-token

# Public base URL — embedded into every playlist stream URL
# SIPTV/VLC/Tivimate users will stream via this host
VVS_BASE_URL=https://stb.example.com
