# vvs-core environment — runs in your office / behind NAT
# Copy to /etc/vvs/core.env and fill in values.

VVS_DB_PATH=/var/lib/vvs/vvs.db
VVS_ADDR=:8080

VVS_ADMIN_USER=admin
VVS_ADMIN_PASSWORD=change-me

# Expose embedded NATS on the WireGuard interface IP so vvs-portal can reach it.
# Set this to the WireGuard interface address, e.g. 10.0.0.1:4222
NATS_LISTEN_ADDR=10.0.0.1:4222

# Shared secret — vvs-portal must supply this token when connecting.
# Generate with: openssl rand -hex 32
NATS_AUTH_TOKEN=replace-with-a-strong-random-token

VVS_BASE_URL=https://portal.example.com
VVS_SECURE_COOKIE=true

# Optional: default VAT rate (percent, integer)
VVS_DEFAULT_VAT_RATE=21

# Optional: session lifetime in seconds (default 86400 = 1 day)
# VVS_SESSION_LIFETIME=86400

# Optional: AES-256-GCM encryption keys (32-byte hex or raw)
# VVS_EMAIL_ENC_KEY=
# VVS_ROUTER_ENC_KEY=
