# vvs-portal environment — runs on public-facing VPS
# Copy to /etc/vvs/portal.env and fill in values.

PORTAL_ADDR=:8081

# WireGuard tunnel IP of vvs-core NATS listener (must match NATS_LISTEN_ADDR in core.env)
NATS_URL=nats://10.0.0.1:4222

# Must match VVS_NATS_PORTAL_PASSWORD in core.env
NATS_PORTAL_PASSWORD=replace-with-a-different-strong-token

VVS_BASE_URL=https://portal.example.com
# PORTAL_INSECURE_COOKIE=true  # uncomment only for local dev without HTTPS
