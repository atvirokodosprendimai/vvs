# VVS ISP Manager — environment configuration
# Copy to .env and fill in values. All variables are optional unless marked required.
# Flags on the CLI override env vars.

# ── Core server ───────────────────────────────────────────────────────────────

# HTTP listen address for the admin UI
VVS_ADDR=:8080

# SQLite database file path (created automatically)
VVS_DB_PATH=./data/vvs.db

# Admin user seeded on startup (idempotent, safe to keep set)
VVS_ADMIN_USER=admin
VVS_ADMIN_PASSWORD=changeme

# Static API bearer token for NATS RPC (leave blank to disable)
VVS_API_TOKEN=

# Public base URL used in generated links (magic-link emails, portal links)
VVS_BASE_URL=http://localhost:8080

# Set to true in production to mark session cookies Secure
VVS_SECURE_COOKIE=false

# Admin session cookie lifetime (e.g. 24h, 7d)
VVS_SESSION_LIFETIME=24h

# Comma-separated module allow-list (leave blank to enable all)
# Available: customer,product,service,network,device,invoice,ticket,deal,contact,task,email,iptv,proxmox
VVS_MODULES=

# Enable demo mode — disables destructive operations (delete, void, etc.)
VVS_DEMO_MODE=false

# Verbose HTTP request logging
VVS_DEBUG=false

# Prometheus metrics server address (leave blank to disable)
VVS_METRICS_ADDR=

# ── NATS ─────────────────────────────────────────────────────────────────────

# Connect to an external NATS server instead of starting the embedded one
NATS_URL=

# Expose the embedded NATS server on this address (for portal binary or NATS CLI)
NATS_LISTEN_ADDR=:4222

# Per-user NATS passwords (recommended over legacy NATS_AUTH_TOKEN)
VVS_NATS_CORE_PASSWORD=
VVS_NATS_PORTAL_PASSWORD=

# ── Encryption keys ───────────────────────────────────────────────────────────
# 32 printable characters each. Used to encrypt credentials at rest in SQLite.
# Generate: openssl rand -base64 24 | tr -d '=' | head -c 32

VVS_ROUTER_ENC_KEY=
VVS_PROXMOX_ENC_KEY=
VVS_DOCKER_ENC_KEY=
VVS_EMAIL_ENC_KEY=

# ── Email / IMAP ──────────────────────────────────────────────────────────────

# How often to poll IMAP inboxes (seconds)
VVS_EMAIL_SYNC_INTERVAL=120

# Emails fetched per sync page
VVS_EMAIL_PAGE_SIZE=50

# ── NetBox IPAM integration (optional) ───────────────────────────────────────

NETBOX_URL=
NETBOX_TOKEN=

# ── Portal chat bot (optional) ────────────────────────────────────────────────

# Ollama API base URL, e.g. http://localhost:11434
VVS_OLLAMA_URL=

# Model name served by Ollama, e.g. llama3, mistral
VVS_BOT_MODEL=

# ── Stripe (optional — required for VM self-service and portal balance top-up) ─

# Get keys at https://dashboard.stripe.com/apikeys
VVS_STRIPE_SECRET_KEY=
VVS_STRIPE_WEBHOOK_SECRET=
VVS_STRIPE_PUBLISHABLE_KEY=

# ── Customer portal binary (vvs-portal) ───────────────────────────────────────
# These are read by cmd/portal/main.go, not the core server.

PORTAL_ADDR=:8081

# NATS URL pointing at the core server (required for portal binary)
# NATS_URL=nats://10.0.0.1:4222

# Password for the 'portal' NATS user (must match VVS_NATS_PORTAL_PASSWORD on core)
# NATS_PORTAL_PASSWORD=

# Disable Secure flag on portal cookies — only for local dev without HTTPS
PORTAL_INSECURE_COOKIE=false
